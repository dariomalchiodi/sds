xt","value":"\nUnless explicitly silenced.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"MEwpOdisXK"},{"type":"break","key":"OYnp5URGKx"},{"type":"text","value":"\nIn the face of ambiguity, refuse the temptation to guess.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"rPrlvUrwUU"},{"type":"break","key":"c4TQaN7IZi"},{"type":"text","value":"\nThere should be one-- and preferably only one --obvious way to do it.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"wfnXNQx7JM"},{"type":"break","key":"BT0E0y6KNo"},{"type":"text","value":"\nAlthough that way may not be obvious at first unless you’re Dutch.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"r63GD3NOYw"},{"type":"break","key":"qA9jgytHju"},{"type":"text","value":"\nNow is better than never.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"zKmA1mPcFi"},{"type":"break","key":"Pr9FHFGVfI"},{"type":"text","value":"\nAlthough never is often better than ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"ITEkt15prC"},{"type":"emphasis","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"right","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"FwbIPRNh5D"}],"key":"q36Nk9C6fq"},{"type":"text","value":" now.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"VLsiJ6ffzf"},{"type":"break","key":"gnOucdGLZK"},{"type":"text","value":"\nIf the implementation is hard to explain, it’s a bad idea.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"XigHuPLvdP"},{"type":"break","key":"yE10Ph0BNo"},{"type":"text","value":"\nIf the implementation is easy to explain, it may be a good idea.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"G7E57Cboa0"},{"type":"break",