    "\n",
    "\n",
    "```{math}\n",
    "p_X(x; n, p) = \\binom{n}{x} p^x (1 - p)^{n - x}\n",
    "               \\mathrm{I}_{\\{0, 1, \\dots, n\\}}(x)\n",
    "```"
   ]
